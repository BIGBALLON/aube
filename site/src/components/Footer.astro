---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="inner">
    <p class="note">
      <span class="serif-en">Content CC BY-NC-SA 4.0 · Code MIT · Non-commercial forever · <span class="nums">{year}</span></span>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    padding: 2.6rem 1.2rem 3rem;
    border-top: 1px solid var(--line);
  }
  .inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.9rem;
    color: var(--ink-soft);
  }
  .wordmark {
    font-family: var(--font-en);
    font-style: italic;
    font-size: 1.05rem;
  }
  .note {
    text-align: center;
    color: var(--ink-soft);
    opacity: 0.75;
    margin: 0;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
  }
  .note .serif-en {
    font-feature-settings: "onum" 1, "liga" 1;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
  }
  .note .nums {
    font-family: var(--font-en);
    font-feature-settings: "onum" 1;
    letter-spacing: 0.04em;
  }
</style>
