---
/**
 * Aube 的反应 · 单书页独立板块
 */
import Seal from './Seal.astro';

interface Props {
  reaction: string;
  sealId?: string;
}

const { reaction, sealId = 'aube-reaction' } = Astro.props;
---

<aside class="aube-reaction">
  <div class="corner">
    <Seal variant="aube-read" size={46} id={sealId} />
  </div>
  <p class="eyebrow"><span class="en">Aube</span> 的反应</p>
  <p class="body">{reaction}</p>
</aside>

<style>
  .aube-reaction {
    margin: 2.6rem 0;
    padding: 1.8rem 2rem 1.5rem;
    background: var(--bg-soft);
    border: 1px solid var(--line);
    border-radius: 2px;
    position: relative;
    box-shadow: 0 1px 0 rgba(30, 27, 24, 0.04), 1px 1px 16px -8px rgba(30, 27, 24, 0.08);
  }
  /* 左侧朱红竖线 */
  .aube-reaction::before {
    content: "";
    position: absolute;
    left: 0;
    top: 14%;
    bottom: 14%;
    width: 2px;
    background: var(--accent-dawn);
    opacity: 0.6;
  }
  .corner {
    position: absolute;
    top: -10px;
    right: -10px;
  }
  .eyebrow {
    font-family: var(--font-cn-title);
    font-size: 0.78rem;
    color: var(--ink-soft);
    letter-spacing: 0.3em;
    margin: 0 0 0.9rem;
    text-transform: none;
  }
  .eyebrow .en {
    font-family: var(--font-en);
    font-style: italic;
    font-weight: 500;
    letter-spacing: 0.06em;
    margin-right: 0.2em;
  }
  .body {
    font-family: var(--font-cn-kai);
    font-size: 1.12rem;
    line-height: 1.95;
    color: var(--ink);
    margin: 0;
    letter-spacing: 0.02em;
    text-indent: 1.2em;
  }
</style>
