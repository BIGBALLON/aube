---
/**
 * 朱砂篆刻方印 · 做旧版
 * 朱砂红 + 白色细线（盖歪的缺墨）+ 缺角 + 微抖
 *
 * - variant="aube"      站点身份印章（EB Garamond italic "aube"）
 * - variant="aube-read" 「讀過」· 单书页读过板块标记
 */
interface Props {
  variant?: 'aube' | 'aube-read';
  size?: number;
  class?: string;
  id?: string;
}
const { variant = 'aube', size = 44, class: className = '', id } = Astro.props;

const isEn = variant === 'aube';
const label = isEn ? 'aube' : '讀過';

const uid = (id ?? `${variant}-${size}`).replace(/[^a-zA-Z0-9_-]/g, '-');
---

<span class={`seal ${className}`} style={`width:${size}px;height:${size}px`} aria-label={isEn ? 'aube' : 'Aube 讀過'}>
  <svg viewBox="0 0 48 48" width={size} height={size}>
    <defs>
      <!-- 做旧纹理：几条白色细线代表朱砂印泥不均 -->
      <pattern id={`seal-grain-${uid}`} x="0" y="0" width="7" height="9" patternUnits="userSpaceOnUse" patternTransform="rotate(14)">
        <path d="M0 4 L7 4" stroke="#F7F2E8" stroke-width="0.3" stroke-opacity="0.28"/>
      </pattern>
      <!-- 缺角的 clip-path -->
      <clipPath id={`seal-clip-${uid}`}>
        <path d="M2 3 L45 2 L46 46 L3 45 L2 3 Z
                 M2 3 L5.5 2.5 L5.5 5.5 L2.5 5.5 Z" fill-rule="evenodd"/>
      </clipPath>
    </defs>

    <!-- 朱砂方印主体（略微旋转 · "盖歪了") -->
    <g transform="rotate(-2.8 24 24)" clip-path={`url(#seal-clip-${uid})`}>
      <rect
        x="2" y="2" width="44" height="44"
        rx="1.2"
        fill="var(--accent-dawn)"
        fill-opacity="0.94"
      />
      <!-- 叠一层朱砂不均纹理 -->
      <rect
        x="2" y="2" width="44" height="44"
        rx="1.2"
        fill={`url(#seal-grain-${uid})`}
      />
      <!-- 内框线 -->
      <rect
        x="5" y="5" width="38" height="38"
        rx="0.6"
        fill="none"
        stroke="#F7F2E8"
        stroke-width="0.7"
        stroke-opacity="0.55"
      />
      <!-- 印文 -->
      {isEn ? (
        <text
          x="24" y="31"
          text-anchor="middle"
          font-family="EB Garamond Variable, EB Garamond, Georgia, serif"
          font-style="italic"
          font-size="19"
          font-weight="500"
          fill="#F7F2E8"
          letter-spacing="0.3"
        >{label}</text>
      ) : (
        <text
          x="24" y="31"
          text-anchor="middle"
          font-family="STKaiti, KaiTi, 'Noto Serif SC', serif"
          font-size="19"
          font-weight="700"
          fill="#F7F2E8"
          letter-spacing="1"
        >{label}</text>
      )}

      <!-- 做旧：几道白色小"缺墨" -->
      <path d="M6 10 L8 10.5" stroke="#F7F2E8" stroke-width="0.5" stroke-opacity="0.5"/>
      <path d="M40 16 L42 17" stroke="#F7F2E8" stroke-width="0.4" stroke-opacity="0.45"/>
      <path d="M10 40 L12 41" stroke="#F7F2E8" stroke-width="0.4" stroke-opacity="0.5"/>
      <path d="M36 38 L40 38" stroke="#F7F2E8" stroke-width="0.5" stroke-opacity="0.38"/>
      <circle cx="30" cy="8" r="0.6" fill="#F7F2E8" fill-opacity="0.35"/>
      <circle cx="14" cy="26" r="0.5" fill="#F7F2E8" fill-opacity="0.3"/>
    </g>
  </svg>
</span>

<style>
  .seal {
    display: inline-block;
    line-height: 0;
    filter: drop-shadow(0 1px 1.5px rgba(193, 74, 58, 0.12));
  }
</style>
