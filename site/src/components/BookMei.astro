---
/**
 * 书眉 · 老书页顶小标
 */
interface Props {
  category?: string;
}
const { category } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<div class="book-mei flex items-center justify-between py-4">
  <a href={base} class="flex items-center gap-2">
    <span class="wordmark text-base">aube</span>
    {category && <>
      <span class="sep">·</span>
      <span>{category}</span>
    </>}
  </a>
  <nav class="hidden md:flex items-center gap-5 text-xs" aria-label="primary">
    <a href={`${base}year`}>按年</a>
    <a href={`${base}about`}>关于</a>
    <a href="https://github.com/BIGBALLON/aube/issues" target="_blank" rel="noopener">反馈</a>
  </nav>
</div>
