---
/**
 * 书卡片 · 用于首页"最新"和归档页
 */
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Seal from './Seal.astro';

interface Props {
  book: CollectionEntry<'books'>;
  dense?: boolean;
}
const { book, dense = false } = Astro.props;
const { title, titleEn, author, oneLiner, verdict, readByAube, coverImage } = book.data;
const base = import.meta.env.BASE_URL;

const verdictClass =
  verdict === '会推' ? 'verdict-yes' :
  verdict === '看情况' ? 'verdict-maybe' : 'verdict-no';
---

<a href={`${base}book/${book.id}`} class={`book-card group ${dense ? 'book-card--dense' : ''}`}>
  <div class="cover">
    <div class={`cover-window ${coverImage ? 'cover-window--image' : ''}`}>
      {coverImage ? (
        <Image
          src={coverImage}
          alt={`${title} 封面`}
          widths={[140, 280]}
          sizes="(max-width: 640px) 80px, 140px"
          class="cover-img"
          loading="lazy"
        />
      ) : (
        <div class="cover-placeholder">
          <span class="cover-title">{title}</span>
          {titleEn && <span class="cover-title-en">{titleEn}</span>}
        </div>
      )}
    </div>
    {readByAube && (
      <div class="cover-seal">
        <Seal variant="aube-read" size={38} id={`book-card-${book.id}`} />
      </div>
    )}
  </div>
  <div class="meta">
    <div class="row1">
      <h3 class="title">{title}</h3>
      <span class={`verdict ${verdictClass}`}>{verdict}</span>
    </div>
    <p class="author">{author}</p>
    <p class="one-liner">{oneLiner}</p>
  </div>
</a>

<style>
  .book-card {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1.6rem;
    padding: 1.5rem 0.4rem 1.5rem 0.4rem;
    border-bottom: 1px solid var(--line);
    align-items: start;
    transition: background 200ms ease, padding 200ms ease;
  }
  .book-card:hover {
    background: var(--bg-soft);
    padding-left: 0.9rem;
  }
  .book-card:last-child {
    border-bottom: none;
  }
  .book-card--dense {
    grid-template-columns: 96px 1fr;
    gap: 1.1rem;
    padding: 1rem 0;
  }

  /* 照片装裱结构
     .cover        = 外层奶白纸托（paper mat），承担 padding / 阴影 / 边框
     .cover-window = 内层 3:4 图窗
     .cover-seal   = 读后朱印，绝对定位贴在纸托边缘 */
  .cover {
    position: relative;
    padding: 6px 6px 10px;
    background:
      linear-gradient(180deg, #FBF7ED 0%, var(--bg) 100%);
    border: 1px solid var(--line);
    border-radius: 1.5px;
    box-shadow:
      0 1px 0 rgba(30, 27, 24, 0.04),
      0 10px 22px -14px rgba(30, 27, 24, 0.22),
      0 3px 6px -3px rgba(193, 74, 58, 0.05),
      inset 1px 0 0 rgba(255, 255, 255, 0.5);
    transition: transform 320ms ease, box-shadow 320ms ease;
  }
  .book-card:hover .cover {
    transform: translateY(-3px);
    box-shadow:
      0 1px 0 rgba(30, 27, 24, 0.04),
      0 18px 32px -14px rgba(30, 27, 24, 0.28),
      0 6px 14px -5px rgba(193, 74, 58, 0.14);
  }
  .cover-window {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(193, 74, 58, 0.05), transparent 60%),
      linear-gradient(180deg, var(--bg-soft) 0%, var(--bg) 100%);
    box-shadow:
      inset 0 0 0 1px rgba(30, 27, 24, 0.05),
      inset 0 1px 2px rgba(30, 27, 24, 0.06);
  }
  .cover-window--image::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(251, 247, 237, 0.16), rgba(251, 247, 237, 0.04) 42%, rgba(30, 27, 24, 0.06)),
      repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.035) 0 1px, transparent 1px 4px);
    box-shadow:
      inset 0 0 0 1px rgba(251, 247, 237, 0.22),
      inset 0 0 22px rgba(251, 247, 237, 0.12);
  }
  .cover-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    padding: 0.8rem;
    text-align: center;
  }
  /* 真实封面图：完整展示在纸托里，方形纸板书也不裁边 */
  .cover-window :global(.cover-img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transform: scale(0.98);
    filter: saturate(0.9) contrast(0.96) brightness(1.03);
    transition: filter 300ms ease, transform 300ms ease;
  }
  .book-card:hover .cover-window :global(.cover-img) {
    transform: scale(1);
    filter: saturate(0.98) contrast(0.99) brightness(1.03);
  }
  .cover-title {
    font-family: var(--font-cn-brush);
    font-weight: 400;
    color: var(--ink);
    font-size: 1.2rem;
    line-height: 1.2;
    letter-spacing: 0.18em;
    writing-mode: vertical-rl;
    text-orientation: upright;
  }
  .cover-title-en {
    font-family: var(--font-en);
    font-style: italic;
    font-size: 0.72rem;
    color: var(--ink-soft);
    position: absolute;
    bottom: 0.5rem;
    left: 0;
    right: 0;
    letter-spacing: 0.04em;
  }
  .cover-seal {
    position: absolute;
    right: -6px;
    bottom: -6px;
  }

  .meta {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-top: 0.2rem;
  }
  .row1 {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .title {
    font-family: var(--font-cn-title);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.3;
    margin: 0;
    letter-spacing: 0.06em;
    transition: color 180ms ease;
  }
  .book-card:hover .title {
    color: var(--accent-dawn);
  }
  .author {
    font-family: var(--font-cn-title);
    font-size: 0.8rem;
    color: var(--ink-soft);
    margin: 0;
    letter-spacing: 0.1em;
  }
  .one-liner {
    font-family: var(--font-cn-kai);
    margin: 0.4rem 0 0;
    font-size: 0.98rem;
    color: var(--ink);
    line-height: 1.75;
    letter-spacing: 0.02em;
  }
  @media (max-width: 640px) {
    .book-card { grid-template-columns: 80px 1fr; gap: 1rem; padding: 1rem 0; }
    .cover-title { font-size: 0.8rem; }
    .title { font-size: 1.1rem; }
    .one-liner { font-size: 0.9rem; }
  }
</style>
