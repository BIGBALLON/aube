---
/**
 * 年度归档 · /year/2025
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookCard from '../../components/BookCard.astro';
import Yuwei from '../../components/Yuwei.astro';
import Seal from '../../components/Seal.astro';
import { getCollection, render } from 'astro:content';
import { getPublishedBooks, getReadYearEntries } from '../../lib/books';

export async function getStaticPaths() {
  const books = await getPublishedBooks();
  const years = await getCollection('years');
  const yearEntries = new Map(years.map((entry) => [entry.data.year, entry]));
  const byYear = new Map(getReadYearEntries(books, 'asc'));

  const allYears = [...new Set<number>([
    ...byYear.keys(),
    ...years.map((y) => y.data.year),
  ])].sort((a, b) => a - b);

  return allYears.map((year, i) => {
    const entry = yearEntries.get(year);
    return {
      params: { year: String(year) },
      props: {
        year,
        books: byYear.get(year) || [],
        yearEntry: entry,
        prevYear: i > 0 ? allYears[i - 1] : null,
        nextYear: i < allYears.length - 1 ? allYears[i + 1] : null,
      },
    };
  });
}

const { year, books, yearEntry, prevYear, nextYear } = Astro.props;
const YearContent = yearEntry ? (await render(yearEntry)).Content : null;
const hasNote = Boolean(YearContent);
const highlight = yearEntry?.data.highlight;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`${year} 年的阅读`} category={String(year)}>
  <article class="year-page">
    <!-- 年份卷首 -->
    <header class="head">
      <p class="eyebrow"><span class="en">by year</span> · 按年浏览</p>
      <h1 class="year-num">{year}</h1>
      <p class="year-label">这一年的阅读</p>
      {highlight && (
        <p class="highlight">
          <span class="quote-mark" aria-hidden="true">「</span>
          {highlight}
          <span class="quote-mark right" aria-hidden="true">」</span>
        </p>
      )}
    </header>

    <Yuwei />

    <!-- 当年记 · 手写话（若有，上提到书单之前） -->
    {hasNote && (
      <section class="year-note prose">
        <header class="note-head">
          <h2 class="note-title">这一年的话</h2>
          <p class="note-by">
            <span class="en">aube</span> · 手写
          </p>
        </header>
        <div class="note-body">
          <YearContent />
        </div>
        <div class="note-seal">
          <Seal variant="aube" size={44} id={`year-note-${year}`} />
        </div>
      </section>
    )}

    {hasNote && <Yuwei />}

    <!-- 这一年的书单 -->
    {books.length === 0 ? (
      <p class="empty">这一年还空着，或者在写。回头再来。</p>
    ) : (
      <section class="list-wrap">
        <header class="list-head">
          <h2 class="list-title">这一年读过的</h2>
          <span class="list-count">共 <span class="nums">{books.length}</span> 本</span>
        </header>
        <div class="list">
          {books.map((book) => <BookCard book={book} />)}
        </div>
      </section>
    )}

    <!-- 跨年导航 -->
    {(prevYear || nextYear) && (
      <>
        <Yuwei />
        <nav class="year-nav" aria-label="跨年">
          {prevYear ? (
            <a href={`${base}year/${prevYear}`} class="year-nav-prev">
              ← <span class="nums">{prevYear}</span> 年
            </a>
          ) : <span />}
          <a href={base} class="year-nav-home">回到首页</a>
          {nextYear ? (
            <a href={`${base}year/${nextYear}`} class="year-nav-next">
              <span class="nums">{nextYear}</span> 年 →
            </a>
          ) : <span />}
        </nav>
      </>
    )}
  </article>
</BaseLayout>

<style>
  .year-page { max-width: 820px; margin: 0 auto; }

  /* 卷首 */
  .head {
    text-align: center;
    padding: 2.4rem 0 0.8rem;
  }
  .eyebrow {
    font-family: var(--font-cn-title);
    font-size: 0.74rem;
    letter-spacing: 0.32em;
    color: var(--accent-mist);
    margin: 0 0 1.2rem;
    text-transform: uppercase;
  }
  .eyebrow .en {
    font-family: var(--font-en);
    font-style: italic;
    letter-spacing: 0.08em;
  }

  .year-num {
    font-family: var(--font-en-decor);
    font-weight: 500;
    font-feature-settings: "onum" 1;
    font-size: clamp(4.5rem, 12vw, 6.5rem);
    color: var(--ink);
    letter-spacing: 0.04em;
    line-height: 1;
    margin: 0;
    display: inline-block;
    position: relative;
  }
  /* 年份下方朱色短横，呼应 hero 的 brand-underline */
  .year-num::after {
    content: "";
    display: block;
    width: 44px;
    height: 1.5px;
    margin: 0.5rem auto 0;
    background: linear-gradient(90deg, transparent, var(--accent-dawn), transparent);
    opacity: 0.7;
  }

  .year-label {
    font-family: var(--font-cn-brush);
    font-weight: 400;
    font-size: 1.15rem;
    color: var(--ink-soft);
    margin: 1.2rem 0 0;
    letter-spacing: 0.5em;
    padding-left: 0.5em;
  }

  .highlight {
    margin: 1.4rem auto 0;
    max-width: 520px;
    color: var(--ink);
    font-family: var(--font-cn-kai);
    font-size: 1.05rem;
    line-height: 1.9;
    letter-spacing: 0.02em;
    position: relative;
    padding: 0 0.5em;
  }
  .quote-mark {
    color: var(--accent-dawn);
    opacity: 0.45;
    font-family: var(--font-cn-brush);
    font-size: 1.4em;
    vertical-align: -0.1em;
    margin: 0 0.1em;
  }

  /* 当年记 · 手写话 */
  .year-note {
    max-width: 680px;
    margin: 1.6rem auto 0;
    padding: 2rem 2.4rem 1.6rem;
    background:
      linear-gradient(180deg, var(--bg-soft) 0%, var(--bg) 100%);
    border: 1px solid var(--line);
    border-radius: 2px;
    position: relative;
    box-shadow:
      0 1px 0 rgba(30, 27, 24, 0.04),
      1px 1px 20px -10px rgba(30, 27, 24, 0.12);
  }
  /* 左侧朱色竖线，像信笺的装饰栏 */
  .year-note::before {
    content: "";
    position: absolute;
    left: 1rem;
    top: 14%;
    bottom: 14%;
    width: 2px;
    background: var(--accent-dawn);
    opacity: 0.5;
  }

  .note-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }
  .note-title {
    font-family: var(--font-cn-brush);
    font-weight: 400;
    font-size: 1.5rem;
    margin: 0;
    letter-spacing: 0.2em;
    color: var(--ink);
    padding-left: 0.5rem;
  }
  .note-title::before { content: none; }
  .note-by {
    font-family: var(--font-cn-title);
    font-size: 0.72rem;
    letter-spacing: 0.24em;
    color: var(--ink-soft);
    margin: 0;
  }
  .note-by .en {
    font-family: var(--font-en);
    font-style: italic;
    margin-right: 0.2em;
  }

  .note-body {
    font-family: var(--font-cn-kai);
    font-size: 1.05rem;
    line-height: 2;
    color: var(--ink);
    letter-spacing: 0.02em;
  }
  .note-body :global(p) {
    margin: 0.8em 0;
    text-indent: 2em;
  }
  .note-body :global(p:first-child) {
    text-indent: 0;
  }
  /* 手写话中的 blockquote */
  .note-body :global(blockquote) {
    margin: 0 0 1.4em;
    padding: 0.4em 1em;
    border-left: 2px solid var(--accent-mist);
    color: var(--ink-soft);
    font-style: italic;
    font-family: var(--font-cn-body);
    font-size: 0.92rem;
  }

  .note-seal {
    text-align: right;
    margin-top: 1.2rem;
    padding-right: 0.2rem;
  }

  /* 书单 */
  .list-wrap {
    max-width: 760px;
    margin: 0 auto;
  }
  .list-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin: 1rem 0 0.4rem;
    padding: 0 0.4rem;
  }
  .list-title {
    font-family: var(--font-cn-brush);
    font-weight: 400;
    font-size: 1.3rem;
    margin: 0;
    letter-spacing: 0.24em;
    color: var(--ink);
  }
  .list-count {
    font-family: var(--font-cn-title);
    font-size: 0.8rem;
    color: var(--ink-soft);
    letter-spacing: 0.2em;
  }
  .list-count .nums {
    font-family: var(--font-en);
    font-feature-settings: "onum" 1;
    color: var(--accent-mist);
  }

  .list {
    margin-top: 0.6rem;
  }

  .empty {
    padding: 3rem 2rem;
    text-align: center;
    color: var(--ink-soft);
    font-style: italic;
    font-family: var(--font-cn-kai);
  }

  /* 跨年导航 */
  .year-nav {
    max-width: 680px;
    margin: 1rem auto 0;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-cn-title);
    font-size: 0.9rem;
    color: var(--ink-soft);
    letter-spacing: 0.1em;
  }
  .year-nav-prev { justify-self: start; }
  .year-nav-next { justify-self: end; }
  .year-nav-home {
    color: var(--accent-mist);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
  }
  .year-nav .nums {
    font-family: var(--font-en);
    font-feature-settings: "onum" 1;
    margin: 0 0.1em;
  }
</style>
