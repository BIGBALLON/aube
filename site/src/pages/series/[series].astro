---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookCard from '../../components/BookCard.astro';
import Yuwei from '../../components/Yuwei.astro';
import { getPublishedBooks, groupBooksBySeries } from '../../lib/books';

export async function getStaticPaths() {
  const books = await getPublishedBooks();
  const bySeries = groupBooksBySeries(books);

  return [...bySeries.entries()].map(([series, seriesBooks]) => ({
    params: { series },
    props: {
      series,
      books: seriesBooks,
    },
  }));
}

const { series, books } = Astro.props;
---

<BaseLayout title={`系列 · ${series}`} category={`系列 · ${series}`}>
  <article class="series-page">
    <header class="head">
      <p class="eyebrow">按系列浏览</p>
      <h1>{series}</h1>
      <p class="series-count">共 <span class="nums">{books.length}</span> 本</p>
    </header>

    <Yuwei />

    <section class="list">
      {books.map((book) => <BookCard book={book} />)}
    </section>
  </article>
</BaseLayout>

<style>
  .series-page { max-width: 720px; margin: 0 auto; }
  .head { text-align: center; padding: 1.5rem 0 0.5rem; }
  .eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    color: var(--ink-soft);
    margin: 0 0 0.6rem;
    text-transform: uppercase;
  }
  h1 {
    font-family: var(--font-cn-brush);
    font-weight: 400;
    font-size: 2.4rem;
    margin: 0;
    color: var(--ink);
    letter-spacing: 0.1em;
  }
  .series-count {
    margin: 0.7rem 0 0;
    font-family: var(--font-cn-title);
    font-size: 0.82rem;
    color: var(--ink-soft);
    letter-spacing: 0.16em;
  }
  .series-count .nums {
    font-family: var(--font-en);
    font-feature-settings: "onum" 1;
    letter-spacing: 0.04em;
    color: var(--accent-dawn);
  }
</style>
